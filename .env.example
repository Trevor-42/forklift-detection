# Copy to `.env` (which is gitignored) and fill in your values.
# Never commit the real .env file.

# Rhombus i2M org API key (get via `rhombus login --profile i2M` then
# read ~/.rhombus/credentials, or generate in the Rhombus console).
RHOMBUS_API_KEY=

# Optional: shared secret Rhombus includes on webhook POSTs (if configured).
WEBHOOK_SECRET=

# Optional: override the forklift-confidence threshold (default 0.70).
CONFIDENCE_THRESHOLD=0.70
